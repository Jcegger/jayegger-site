---
layout: base.njk
title: Blog
description: Posts on SEO, GEO, CRO, and content strategy by Jay Egger.
permalink: /blog/
---
<header>
    <div class="marquee" aria-hidden="true"><span>Blog • SEO · GEO · CRO · content systems • Updated when vibes allow • </span></div>
    <div class="card">
      <div class="accent">Blog</div>
      <h1>Writing on SEO, GEO, CRO, and content systems</h1>
      <p class="meta">Subscribe via RSS or check the latest below.</p>
    </div>
  </header>

  <main>
    <section class="card">
      <div class="grid-2">
        {% for post in collections.posts %}
          {% set tagLine = '' %}
          {% if post.data.tags and (post.data.tags | length) > 0 %}
            {% set tagLine = post.data.tags | join(', ') %}
          {% endif %}
          <article>
            <div class="meta">{{ post.date | readableDate }}{% if tagLine %} · {{ tagLine }}{% endif %}</div>
            <h2><a href="{{ post.url | url }}">{{ post.data.title }}</a></h2>
            <p>{{ post.data.excerpt or post.data.description }}</p>
            {% if post.data.tags and (post.data.tags | length) > 0 %}
              <div class="tags">
                {% for tag in post.data.tags %}
                  <span class="tag">{{ tag }}</span>
                {% endfor %}
              </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    </section>
  </main>

  <footer>
    <div class="btn-row">
      <a class="btn secondary" href="{{ '/' | url }}">Home</a>
      <a class="btn secondary" href="{{ '/rss.xml' | url }}">RSS</a>
    </div>
  </footer>
