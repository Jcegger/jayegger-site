<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title or site.title }}</title>
  <meta name="description" content="{{ description or site.description }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Syne+Mono&display=swap" as="style">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Syne+Mono&display=swap">
  <link rel="stylesheet" href="{{ '/styles.css' | url }}">
  <link rel="icon" href="{{ '/assets/favicon.svg' | url }}">
  <link rel="alternate" type="application/rss+xml" title="Jay Egger RSS" href="{{ '/rss.xml' | url }}">
  <meta property="og:title" content="{{ title or site.title }}" />
  <meta property="og:description" content="{{ description or site.description }}" />
  <meta property="og:type" content="{{ ogType or 'website' }}" />
  <meta property="og:url" content="{{ page.url | url | absolute(site.url) }}" />
  <meta property="og:image" content="{{ '/assets/og-image.svg' | url | absolute(site.url) }}" />
  <meta name="twitter:card" content="summary_large_image" />
</head>
<body>
  <div class="shell">
    <div class="layout">
      <aside class="sidebar">
        <a class="nav-btn" href="{{ '/' | url }}">Home</a>
        <a class="nav-btn" href="{{ '/about/' | url }}">About</a>
        <a class="nav-btn" href="{{ '/blog/' | url }}">Blog</a>
        <a class="nav-btn" href="{{ '/contact/' | url }}">Contact</a>
        <div class="badge-row">
          <img src="{{ '/assets/88x31-personal.svg' | url }}" alt="88x31 badge: personal" height="31" width="88">
          <img src="{{ '/assets/88x31-retro.svg' | url }}" alt="88x31 badge: retro" height="31" width="88">
          <img src="{{ '/assets/88x31-construction.svg' | url }}" alt="88x31 badge: under construction" height="31" width="88">
        </div>
        <div class="note">Burnt orange, pixels, semantic HTML, RSS-ready.</div>
      </aside>

      <div class="main">
        {% block body %}{% endblock %}
        <footer>
          <div class="accent">Under construction · Est. 2026</div>
          <p class="meta">Made with burnt orange, pixels, and semantic HTML. GA anonymized.</p>
        </footer>
      </div>
    </div>
  </div>

  <script async src="{{ '/scripts.js' | url }}"></script>
  {% if site.gaId and site.gaId != 'GA_MEASUREMENT_ID' %}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.gaId }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.gaId }}', { 'anonymize_ip': true });
  </script>
  {% endif %}
</body>
</html>
