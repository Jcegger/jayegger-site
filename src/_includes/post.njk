---
layout: base.njk
ogType: article
---
{% set metaDate = date | readableDate %}
{% if updated %}
  {% set updatedDate = updated | readableDate %}
{% else %}
  {% set updatedDate = null %}
{% endif %}
{% set postImage = featuredImage or '/assets/og-image.png' %}
{% set primaryTag = 'blog' %}
{% if tags and (tags | length) > 0 %}
  {% set primaryTag = tags[0] %}
{% endif %}
{% set marqueeText = 'Blog' %}
{% if tags and (tags | length) > 0 %}
  {% set marqueeText = tags | join(' · ') %}
{% endif %}
  <header>
    <div class="marquee" aria-hidden="true"><span>{{ marqueeText }} • {{ title }} • </span></div>
    <div class="card">
      <div class="accent">Blog · {{ primaryTag }}</div>
      <h1>{{ title }}</h1>
      <p class="meta">By {{ site.author }} • {{ metaDate }}{% if updatedDate %} · Updated {{ updatedDate }}{% endif %}</p>
    </div>
  </header>

  <main>
    <article class="card">
      {{ content | safe }}
    </article>
  </main>

  <footer>
    <div class="btn-row">
      <a class="btn secondary" href="{{ '/blog/' | url }}">Back to blog</a>
      <a class="btn secondary" href="{{ '/' | url }}">Home</a>
    </div>
  </footer>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{{ title | escape }}",
    "description": "{{ description or excerpt or site.description | escape }}",
    "author": {
      "@type": "Person",
      "name": "{{ site.author | escape }}"
    },
    "datePublished": "{{ date | isoDate }}",
    "dateModified": "{{ (updated or date) | isoDate }}",
    "mainEntityOfPage": "{{ page.url | url | absolute(site.url) }}",
    "image": "{{ postImage | url | absolute(site.url) }}",
    "publisher": {
      "@type": "Person",
      "name": "{{ site.author | escape }}"
    }
  }
  </script>
