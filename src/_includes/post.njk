---
layout: base.njk
ogType: article
---
{% set metaDate = date | readableDate %}
{% if updated %}
  {% set updatedDate = updated | readableDate %}
{% else %}
  {% set updatedDate = null %}
{% endif %}
{% set postImage = featuredImage or '/assets/og-image.svg' %}
  <header>
    <div class="marquee" aria-hidden="true"><span>{{ tags | join(' · ') }} • {{ title }} • </span></div>
    <div class="card">
      <div class="accent">Blog · {{ tags and tags[1] or 'post' }}</div>
      <h1>{{ title }}</h1>
      <p class="meta">By {{ site.author }} • {{ metaDate }}{% if updatedDate %} · Updated {{ updatedDate }}{% endif %}</p>
    </div>
  </header>

  <main>
    <article class="card">
      {{ content | safe }}
    </article>
  </main>

  <footer>
    <div class="btn-row">
      <a class="btn secondary" href="{{ '/blog/index.html' | url }}">Back to blog</a>
      <a class="btn secondary" href="{{ '/index.html' | url }}">Home</a>
    </div>
  </footer>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{{ title | escape }}",
    "description": "{{ description or excerpt or site.description | escape }}",
    "author": {
      "@type": "Person",
      "name": "{{ site.author | escape }}"
    },
    "datePublished": "{{ date | isoDate }}",
    "dateModified": "{{ (updated or date) | isoDate }}",
    "mainEntityOfPage": "{{ page.url | url | absolute(site.url) }}",
    "image": "{{ postImage | url | absolute(site.url) }}",
    "publisher": {
      "@type": "Person",
      "name": "{{ site.author | escape }}"
    }
  }
  </script>
